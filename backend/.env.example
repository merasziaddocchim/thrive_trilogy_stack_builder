# Neon pooled connection string (use the POOLED endpoint to absorb scale-to-zero reconnect latency, per TECH_DOCS §5)
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Server
PORT=8080
NODE_ENV=development

# CORS: the frontend origin (Vercel deployment / local dev)
FRONTEND_ORIGIN=http://localhost:3000
