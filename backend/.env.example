# Neon pooled connection string (use the POOLED endpoint to absorb scale-to-zero reconnect latency, per TECH_DOCS §5)
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require

# Server
PORT=8080
NODE_ENV=development

# CORS: allowed frontend origin(s), comma-separated (production app + local dev).
# In Render, set this to the live app origin (include localhost only if you also hit the
# deployed backend from local dev). No trailing slash. Must exactly match the browser origin.
FRONTEND_ORIGIN=https://app.thrivetrilogy.com,http://localhost:3000
