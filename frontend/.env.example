# Backend API base URL (Render). Marketing/methodology pages must NOT hard-depend on this
# being warm (TECH_DOCS §5) - only the interactive assessment flow calls it.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Canonical public origin of the app (used for sitemap/canonical tags, TECH_DOCS §7).
NEXT_PUBLIC_SITE_URL=https://app.thrivetrilogy.com
